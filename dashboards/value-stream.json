          "rawQuery": true,
          "rawSql": "SELECT COUNT(DISTINCT deployment_id) AS journey_count\nFROM vsi_stage_breakdown s\nWHERE s.recorded_at >= NOW() - INTERVAL '1 $window';",
          "refId": "A",
          "select": [
